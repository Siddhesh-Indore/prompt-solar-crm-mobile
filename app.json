{
  "expo": {
    "name": "Prompt CRM",
    "slug": "prompt-solar-crm-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "promptsolarcrmmobile",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon"
    },
    "android": {
      "package": "com.promptsolar.crm",
      "versionCode": 5,
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#E6F4FE",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 160
        }
      ],
      "@react-native-community/datetimepicker",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Prompt Solar CRM uses your location to tag where each site visit happened."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Prompt Solar CRM accesses your photos so you can attach a site photo to a visit.",
          "cameraPermission": "Prompt Solar CRM uses your camera to take a site photo for a visit."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ae810268-ad43-475c-b9ee-ae6d88c839da"
      }
    },
    "owner": "prompt-co"
  }
}
